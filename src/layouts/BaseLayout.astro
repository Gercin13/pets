---
// Base document shell: fonts, Header + Footer, and SEO alternates.
// Emits canonical + hreflang (en / de / uk / x-default). Pages that know their
// per-language URLs (e.g. article pages) pass `localeLinks` so both the Header
// switcher AND the hreflang tags point at the real translations.
import { getLangFromUrl, stripLang } from '../i18n/utils';
import { languages, defaultLang } from '../i18n/ui';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';

interface Props {
  title?: string;
  description?: string;
  /** Optional map { en, de, uk } → URL, e.g. from getTranslationLinks() on article pages. */
  localeLinks?: Partial<Record<string, string>>;
}
const { title = 'PetExpert', description, localeLinks } = Astro.props;

const lang = getLangFromUrl(Astro.url);

// Absolute alternates for SEO. `Astro.site` comes from `site` in astro.config.mjs.
const site = Astro.site ?? new URL('https://petexpert.com');
const basePath = stripLang(Astro.url.pathname); // "/" or "/health/…"
const suffix = basePath === '/' ? '' : basePath;
// Prefer explicit per-language URLs (article translations) over the generic path swap.
const hrefFor = (loc: string) =>
  new URL(localeLinks?.[loc] ?? `/${loc}${suffix}`, site).href;
const localeCodes = Object.keys(languages);
---

<!doctype html>
<html lang={lang} class="scroll-smooth">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{title}</title>
    {description && <meta name="description" content={description} />}

    <!-- Canonical + hreflang alternates for the three locales -->
    <link rel="canonical" href={hrefFor(lang)} />
    {localeCodes.map((loc) => <link rel="alternate" hreflang={loc} href={hrefFor(loc)} />)}
    <link rel="alternate" hreflang="x-default" href={hrefFor(defaultLang)} />

    <!-- "Warm Professionalism" type pairing: Source Serif 4 + Plus Jakarta Sans -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:wght@400;500;600;700&family=Source+Serif+4:opsz,wght@8..60,400;8..60,600;8..60,700&display=swap"
      rel="stylesheet"
    />
  </head>
  <body class="flex min-h-screen flex-col bg-warm-sand font-sans text-charcoal antialiased">
    <Header localeLinks={localeLinks} />
    <main class="flex-1">
      <slot />
    </main>
    <Footer />
  </body>
</html>
