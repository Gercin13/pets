---
// Detailed article template (Layout 2). Use as the `layout` in a Markdown/MDX file:
//   ---
//   layout: ../../../layouts/ArticleLayout.astro
//   title: ...
//   ---
// Reading column is capped at 720px and centered; a sticky "Related articles" sidebar
// sits on the right (desktop) and drops below the article on mobile.
import BaseLayout from './BaseLayout.astro';
import { getLangFromUrl, useTranslations, localizePath } from '../i18n/utils';

const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);
// Markdown/MDX layouts receive `frontmatter` on Astro.props; type it loosely for strict TS.
const { frontmatter } = Astro.props as { frontmatter?: Record<string, any> };

// Frontmatter shape (fallbacks keep the template renderable on its own):
const {
  title = 'Untitled article',
  category,
  author = { name: 'Dr. Anna Smirnova', avatar: '/img/authors/anna-smirnova.jpg', verified: true },
  readingTime = '8 min read',
  pubDate,
  heroImage,
  heroAlt = '',
  related = [],
  comments = [],
} = frontmatter ?? {};

const formattedDate = pubDate
  ? new Date(pubDate).toLocaleDateString(lang, { year: 'numeric', month: 'long', day: 'numeric' })
  : '';
---

<BaseLayout title={title}>
  <div class="mx-auto max-w-7xl px-4 py-10 sm:px-6 lg:px-8 lg:py-16">
    <div class="lg:grid lg:grid-cols-[minmax(0,1fr)_20rem] lg:gap-12 xl:gap-20">
      <!-- ===================== MAIN ARTICLE ===================== -->
      <article class="min-w-0">
        <!-- Header block (reading width) -->
        <div class="mx-auto max-w-[720px]">
          <nav aria-label="Breadcrumb" class="font-sans text-label-sm text-charcoal/50">
            <a href={localizePath('/', lang)} class="transition-colors hover:text-charcoal">{t('crumb.home')}</a>
            <span aria-hidden="true" class="px-1.5 text-charcoal/30">/</span>
            <a href={localizePath('/health', lang)} class="transition-colors hover:text-charcoal">{t('nav.health')}</a>
          </nav>

          {category && (
            <span class="mt-6 inline-block rounded-full bg-terracotta px-3 py-1 font-sans text-label-sm font-bold text-warm-sand">
              {category}
            </span>
          )}

          <h1 class="mt-4 font-serif text-[2rem] font-bold leading-tight text-charcoal sm:text-4xl md:text-5xl">
            {title}
          </h1>

          <!-- Author block -->
          <div class="mt-6 flex items-center gap-4 border-b border-charcoal/10 pb-6">
            <img src={author.avatar} alt={author.name} class="h-12 w-12 shrink-0 rounded-full object-cover ring-2 ring-surface-lowest" />
            <div class="min-w-0">
              <div class="flex flex-wrap items-center gap-x-2 gap-y-1">
                <span class="font-sans font-bold text-charcoal">{author.name}</span>
                {author.verified && (
                  <span class="inline-flex items-center gap-1 rounded-full bg-primary/10 px-2 py-0.5 font-sans text-label-sm font-bold text-primary">
                    <svg viewBox="0 0 20 20" fill="currentColor" class="h-3.5 w-3.5">
                      <path fill-rule="evenodd" d="M16.403 12.652a3 3 0 0 0 0-5.304 3 3 0 0 0-3.75-3.751 3 3 0 0 0-5.305 0 3 3 0 0 0-3.751 3.75 3 3 0 0 0 0 5.305 3 3 0 0 0 3.75 3.751 3 3 0 0 0 5.305 0 3 3 0 0 0 3.751-3.75Zm-2.546-4.46a.75.75 0 0 0-1.214-.883l-3.483 4.79-1.88-1.88a.75.75 0 1 0-1.06 1.061l2.5 2.5a.75.75 0 0 0 1.137-.089l4-5.5Z" clip-rule="evenodd" />
                    </svg>
                    {t('article.verified')}
                  </span>
                )}
              </div>
              <div class="mt-0.5 font-sans text-label-sm text-charcoal/50">
                <span>{readingTime}</span>
                {formattedDate && (
                  <>
                    <span aria-hidden="true" class="px-1.5">·</span>
                    <time datetime={pubDate}>{formattedDate}</time>
                  </>
                )}
              </div>
            </div>
          </div>
        </div>

        <!-- Hero image -->
        {heroImage && (
          <figure class="mx-auto mt-8 max-w-[720px]">
            <img src={heroImage} alt={heroAlt} class="aspect-[16/9] w-full rounded-lg object-cover" />
          </figure>
        )}

        <!-- Rendered Markdown body (reading column) -->
        <div class="article-body mx-auto mt-8 max-w-[720px]">
          <slot />
        </div>

        <!-- Comments -->
        <section aria-labelledby="comments-heading" class="mx-auto mt-14 max-w-[720px] border-t border-charcoal/10 pt-10">
          <h2 id="comments-heading" class="font-serif text-2xl font-bold text-charcoal">
            {t('comments.title')} <span class="text-charcoal/40">({comments.length})</span>
          </h2>

          <!-- New comment form -->
          <form class="mt-6">
            <label for="comment" class="font-sans text-label-bold text-charcoal">{t('comments.leave')}</label>
            <textarea
              id="comment"
              name="comment"
              rows="4"
              placeholder={t('comments.placeholder')}
              class="mt-2 w-full resize-y rounded-lg border border-outline bg-surface-lowest p-4 font-sans text-sm text-charcoal placeholder:text-charcoal/40 focus:border-primary focus:outline-none focus:ring-2 focus:ring-primary/20"
            ></textarea>
            <div class="mt-3 flex justify-end">
              <button type="submit" class="rounded-lg bg-primary px-5 py-2.5 font-sans text-label-bold text-warm-sand transition-colors hover:bg-primary/90">
                {t('comments.submit')}
              </button>
            </div>
          </form>

          <!-- Existing thread -->
          <ul class="mt-10 space-y-8">
            {comments.map((c: any) => (
              <li>
                <div class="flex gap-4">
                  <img src={c.avatar} alt={c.author} class="h-10 w-10 shrink-0 rounded-full object-cover" />
                  <div class="min-w-0 flex-1">
                    <div class="flex flex-wrap items-center gap-x-2 gap-y-1">
                      <span class="font-sans text-sm font-bold text-charcoal">{c.author}</span>
                      {c.isVet && (
                        <span class="inline-flex items-center gap-1 rounded-full bg-primary/10 px-2 py-0.5 font-sans text-label-sm font-bold text-primary">{t('comments.vet')}</span>
                      )}
                      <span class="font-sans text-label-sm text-charcoal/40">{c.date}</span>
                    </div>
                    <p class="mt-1.5 font-sans text-sm leading-relaxed text-charcoal/80">{c.text}</p>
                    <button type="button" class="mt-2 font-sans text-label-sm font-bold text-primary hover:underline">{t('comments.reply')}</button>
                  </div>
                </div>

                {c.replies && c.replies.length > 0 && (
                  <ul class="mt-6 space-y-6 border-l-2 border-primary/15 pl-5 sm:ml-14">
                    {c.replies.map((r: any) => (
                      <li class="flex gap-4">
                        <img src={r.avatar} alt={r.author} class="h-10 w-10 shrink-0 rounded-full object-cover" />
                        <div class="min-w-0 flex-1">
                          <div class="flex flex-wrap items-center gap-x-2 gap-y-1">
                            <span class="font-sans text-sm font-bold text-charcoal">{r.author}</span>
                            {r.isVet && (
                              <span class="inline-flex items-center gap-1 rounded-full bg-primary/10 px-2 py-0.5 font-sans text-label-sm font-bold text-primary">
                                <svg viewBox="0 0 20 20" fill="currentColor" class="h-3 w-3"><path fill-rule="evenodd" d="M16.403 12.652a3 3 0 0 0 0-5.304 3 3 0 0 0-3.75-3.751 3 3 0 0 0-5.305 0 3 3 0 0 0-3.751 3.75 3 3 0 0 0 0 5.305 3 3 0 0 0 3.75 3.751 3 3 0 0 0 5.305 0 3 3 0 0 0 3.751-3.75Zm-2.546-4.46a.75.75 0 0 0-1.214-.883l-3.483 4.79-1.88-1.88a.75.75 0 1 0-1.06 1.061l2.5 2.5a.75.75 0 0 0 1.137-.089l4-5.5Z" clip-rule="evenodd" /></svg>
                                {t('comments.vet')}
                              </span>
                            )}
                            <span class="font-sans text-label-sm text-charcoal/40">{r.date}</span>
                          </div>
                          <p class="mt-1.5 font-sans text-sm leading-relaxed text-charcoal/80">{r.text}</p>
                        </div>
                      </li>
                    ))}
                  </ul>
                )}
              </li>
            ))}
          </ul>
        </section>
      </article>

      <!-- ===================== RELATED SIDEBAR ===================== -->
      {related.length > 0 && (
        <aside class="mt-14 lg:mt-0 lg:sticky lg:top-24 lg:self-start">
          <h2 class="font-serif text-lg font-bold text-charcoal">{t('article.related')}</h2>
          <ul class="mt-4 space-y-5">
            {related.map((r: any) => (
              <li>
                <a href={r.href} class="group flex items-start gap-4">
                  <img src={r.image} alt={r.title} class="h-16 w-16 shrink-0 rounded-lg object-cover" loading="lazy" />
                  <div class="min-w-0">
                    <h3 class="font-serif text-base font-bold leading-snug text-charcoal transition-colors group-hover:text-primary">{r.title}</h3>
                    <span class="mt-1 block font-sans text-label-sm text-charcoal/50">{r.readingTime}</span>
                  </div>
                </a>
              </li>
            ))}
          </ul>
        </aside>
      )}
    </div>
  </div>
</BaseLayout>

<style is:global>
  /* Reading typography for rendered Markdown.
     Dependency-free (no @tailwindcss/typography). :where() keeps specificity at 0 so
     utility classes win, and :not(.not-prose *) keeps it away from embedded components
     like <ProductCard> (which carries a `not-prose` root). */
  .article-body :where(p):not(:where(.not-prose, .not-prose *)) {
    margin: 1.25rem 0;
    font-size: 1.0625rem;
    line-height: 1.75;
    color: rgba(30, 27, 24, 0.85);
  }
  .article-body :where(h2):not(:where(.not-prose, .not-prose *)) {
    margin: 2.25rem 0 0.75rem;
    font-family: "Source Serif 4", Georgia, serif;
    font-size: 1.6rem;
    font-weight: 700;
    line-height: 1.25;
    color: #1e1b18;
  }
  .article-body :where(h3):not(:where(.not-prose, .not-prose *)) {
    margin: 1.75rem 0 0.5rem;
    font-family: "Source Serif 4", Georgia, serif;
    font-size: 1.3rem;
    font-weight: 700;
    color: #1e1b18;
  }
  .article-body :where(ul, ol):not(:where(.not-prose, .not-prose *)) {
    margin: 1.25rem 0;
    padding-left: 1.4rem;
    font-size: 1.0625rem;
    line-height: 1.75;
    color: rgba(30, 27, 24, 0.85);
  }
  .article-body :where(ul):not(:where(.not-prose, .not-prose *)) { list-style: disc; }
  .article-body :where(ol):not(:where(.not-prose, .not-prose *)) { list-style: decimal; }
  .article-body :where(li):not(:where(.not-prose, .not-prose *)) { margin: 0.4rem 0; }
  .article-body :where(li)::marker { color: #334f2b; }
  .article-body :where(a):not(:where(.not-prose, .not-prose *)) {
    color: #334f2b;
    font-weight: 500;
    text-decoration: underline;
    text-underline-offset: 2px;
  }
  .article-body :where(a):not(:where(.not-prose, .not-prose *)):hover { color: #822a19; }
  .article-body :where(strong):not(:where(.not-prose, .not-prose *)) { color: #1e1b18; font-weight: 700; }
  .article-body :where(img):not(:where(.not-prose, .not-prose *)) { border-radius: 0.75rem; margin: 1.75rem 0; }

  /* Author quote callout */
  .article-body :where(blockquote):not(:where(.not-prose, .not-prose *)) {
    margin: 2rem 0;
    border-left: 4px solid #822a19;
    background: rgba(130, 42, 25, 0.04);
    padding: 1rem 1.5rem;
    border-radius: 0 0.5rem 0.5rem 0;
    font-family: "Source Serif 4", Georgia, serif;
    font-style: italic;
    font-size: 1.25rem;
    line-height: 1.6;
    color: #1e1b18;
  }
  .article-body :where(blockquote p):not(:where(.not-prose, .not-prose *)) {
    margin: 0;
    font-size: inherit;
    color: inherit;
  }
  .article-body :where(blockquote cite),
  .article-body :where(blockquote footer) {
    display: block;
    margin-top: 0.75rem;
    font-family: "Plus Jakarta Sans", sans-serif;
    font-style: normal;
    font-size: 0.875rem;
    font-weight: 700;
    color: #822a19;
  }
</style>
