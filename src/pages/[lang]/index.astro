---
// PetExpert homepage (Layout 4). Fully localized — every visible string comes from t().
// Renders at /en, /de, /uk. Images/hrefs live in the data below (swap for a CMS).
import BaseLayout from '../../layouts/BaseLayout.astro';
import { languages } from '../../i18n/ui';
import { getLangFromUrl, useTranslations, localizePath } from '../../i18n/utils';
import { getSectionPosts, getPostByKey, postHref } from '../../lib/posts';

export function getStaticPaths() {
  return Object.keys(languages).map((lang) => ({ params: { lang } }));
}

const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);

// Non-translatable content (media, proper nouns, links).
const heroImage = '/img/home/hero-sofa.jpg';
// Featured card links to the real nutrition article (newest in the section).
// Falls back to the section page if no nutrition articles exist yet.
const nutritionPosts = await getSectionPosts(lang, 'nutrition');
const featured = {
  image: '/img/home/natural-feeding.jpg',
  author: 'Dr. Anna Smirnova',
  avatar: '/img/authors/anna-smirnova.jpg',
  href: nutritionPosts[0] ? postHref(nutritionPosts[0], lang) : localizePath('/nutrition', lang),
};
// Both teaser cards now link to the real article matching their (already-translated)
// title/category copy below — falls back to /health if that article is ever removed.
const kittenPost = await getPostByKey(lang, 'new-kitten-first-30-days');
const seniorPost = await getPostByKey(lang, 'senior-dog-care');
const card1 = {
  image: '/img/home/kitten.jpg',
  href: kittenPost ? postHref(kittenPost, lang) : localizePath('/health', lang),
};
const card2 = {
  image: '/img/home/senior-dog.jpg',
  href: seniorPost ? postHref(seniorPost, lang) : localizePath('/health', lang),
};

const arrow =
  'M3 10a.75.75 0 0 1 .75-.75h10.638L10.23 5.29a.75.75 0 1 1 1.04-1.08l5.5 5.25a.75.75 0 0 1 0 1.08l-5.5 5.25a.75.75 0 1 1-1.04-1.08l4.158-3.96H3.75A.75.75 0 0 1 3 10Z';
---

<BaseLayout title="PetExpert" description={t('home.hero.subtitle')}>
  <!-- ===================== HERO ===================== -->
  <section class="mx-auto max-w-7xl px-4 py-12 sm:px-6 lg:px-8 lg:py-20">
    <div class="grid items-center gap-10 lg:grid-cols-2 lg:gap-16">
      <!-- Left: copy + search -->
      <div>
        <h1 class="font-serif text-[2.5rem] font-bold leading-[1.05] tracking-tight text-primary md:text-display-lg">
          {t('home.hero.title')}
        </h1>
        <p class="mt-6 max-w-xl font-sans text-lg leading-relaxed text-charcoal/70">{t('home.hero.subtitle')}</p>
        <form id="hero-search" class="mt-8 max-w-md" role="search" action={localizePath('/search', lang)}>
          <label for="site-search" class="sr-only">{t('home.hero.search')}</label>
          <div class="relative">
            <span class="pointer-events-none absolute inset-y-0 left-0 flex items-center pl-4 text-charcoal/40">
              <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.8" stroke="currentColor" class="h-5 w-5">
                <path stroke-linecap="round" stroke-linejoin="round" d="m21 21-5.197-5.197m0 0A7.5 7.5 0 1 0 5.196 5.196a7.5 7.5 0 0 0 10.607 10.607Z" />
              </svg>
            </span>
            <input
              id="site-search"
              type="search"
              name="q"
              placeholder={t('home.hero.search')}
              class="w-full rounded-full border border-outline bg-surface-lowest py-3.5 pl-12 pr-4 font-sans text-charcoal shadow-sm transition-shadow placeholder:text-charcoal/40 focus:border-primary focus:outline-none focus:ring-2 focus:ring-primary/20"
            />
          </div>
        </form>
      </div>

      <!-- Right: hero image -->
      <div class="relative">
        <img src={heroImage} alt={t('home.hero.imageAlt')} class="w-full rounded-xl object-cover shadow-xl ring-1 ring-charcoal/5" />
      </div>
    </div>
  </section>

  <!-- ===================== LATEST ARTICLES ===================== -->
  <section class="mx-auto max-w-7xl px-4 pb-16 sm:px-6 lg:px-8">
    <div class="flex items-end justify-between gap-4">
      <h2 class="font-serif text-3xl font-bold text-charcoal md:text-4xl">{t('home.latest.title')}</h2>
      <a href={localizePath('/blog', lang)} class="group inline-flex shrink-0 items-center gap-1.5 font-sans text-label-bold text-primary">
        {t('home.latest.viewAll')}
        <svg viewBox="0 0 20 20" fill="currentColor" class="h-4 w-4 transition-transform group-hover:translate-x-1"><path fill-rule="evenodd" d={arrow} clip-rule="evenodd" /></svg>
      </a>
    </div>

    <div class="mt-8 grid gap-6 lg:grid-cols-2">
      <!-- Featured card: text over dark image gradient -->
      <a href={featured.href} class="group relative flex min-h-[24rem] flex-col justify-end overflow-hidden rounded-lg p-6 shadow-sm ring-1 ring-charcoal/5 sm:p-8 lg:min-h-[30rem]">
        <img src={featured.image} alt="" class="absolute inset-0 h-full w-full object-cover transition-transform duration-500 group-hover:scale-105" />
        <div class="absolute inset-0 bg-gradient-to-t from-charcoal/90 via-charcoal/45 to-transparent"></div>
        <div class="relative">
          <span class="inline-block rounded-full bg-terracotta px-3 py-1 font-sans text-label-sm font-bold text-warm-sand">{t('home.featured.category')}</span>
          <h3 class="mt-3 max-w-xl font-serif text-2xl font-bold leading-snug text-warm-sand md:text-3xl">{t('home.featured.title')}</h3>
          <p class="mt-2 max-w-lg font-sans text-sm leading-relaxed text-warm-sand/80">{t('home.featured.excerpt')}</p>
          <div class="mt-5 flex items-center gap-3">
            <img src={featured.avatar} alt={featured.author} class="h-9 w-9 rounded-full object-cover ring-2 ring-warm-sand/30" />
            <div class="font-sans text-label-sm text-warm-sand/80">
              <span class="font-bold text-warm-sand">{featured.author}</span> · {t('home.featured.readingTime')}
            </div>
          </div>
        </div>
      </a>

      <!-- Two small horizontal cards -->
      <div class="flex flex-col gap-6">
        <a href={card1.href} class="group flex flex-1 overflow-hidden rounded-lg bg-surface-lowest shadow-sm ring-1 ring-charcoal/5 transition-shadow hover:shadow-md">
          <img src={card1.image} alt="" class="w-2/5 shrink-0 object-cover" />
          <div class="flex flex-1 flex-col justify-center p-5">
            <span class="w-fit rounded-full bg-primary/10 px-2.5 py-0.5 font-sans text-label-sm font-bold text-primary">{t('home.card1.category')}</span>
            <h3 class="mt-2 font-serif text-lg font-bold leading-snug text-charcoal transition-colors group-hover:text-primary">{t('home.card1.title')}</h3>
            <span class="mt-2 font-sans text-label-sm text-charcoal/50">{t('home.card1.readingTime')}</span>
          </div>
        </a>
        <a href={card2.href} class="group flex flex-1 overflow-hidden rounded-lg bg-surface-lowest shadow-sm ring-1 ring-charcoal/5 transition-shadow hover:shadow-md">
          <img src={card2.image} alt="" class="w-2/5 shrink-0 object-cover" />
          <div class="flex flex-1 flex-col justify-center p-5">
            <span class="w-fit rounded-full bg-primary/10 px-2.5 py-0.5 font-sans text-label-sm font-bold text-primary">{t('home.card2.category')}</span>
            <h3 class="mt-2 font-serif text-lg font-bold leading-snug text-charcoal transition-colors group-hover:text-primary">{t('home.card2.title')}</h3>
            <span class="mt-2 font-sans text-label-sm text-charcoal/50">{t('home.card2.readingTime')}</span>
          </div>
        </a>
      </div>
    </div>
  </section>

  <!-- ===================== NEWSLETTER ===================== -->
  <section class="mx-auto max-w-7xl px-4 pb-20 sm:px-6 lg:px-8">
    <div class="rounded-lg bg-primary px-6 py-10 sm:px-10 lg:px-14 lg:py-12">
      <div class="flex flex-col gap-8 lg:flex-row lg:items-center lg:justify-between">
        <div class="max-w-xl">
          <h2 class="font-serif text-2xl font-bold text-warm-sand md:text-3xl">{t('home.news.title')}</h2>
          <p class="mt-3 font-sans leading-relaxed text-warm-sand/80">{t('home.news.text')}</p>
        </div>
        <form class="w-full lg:w-auto lg:shrink-0" action={localizePath('/subscribe', lang)} method="post">
          <div class="flex flex-col gap-3 sm:flex-row">
            <label for="news-email" class="sr-only">{t('home.news.placeholder')}</label>
            <input
              id="news-email"
              type="email"
              name="email"
              required
              placeholder={t('home.news.placeholder')}
              class="w-full rounded-lg border-0 bg-surface-lowest px-4 py-3 font-sans text-charcoal placeholder:text-charcoal/40 focus:outline-none focus:ring-2 focus:ring-warm-sand/60 sm:w-72"
            />
            <button type="submit" class="rounded-lg bg-terracotta px-6 py-3 font-sans text-label-bold text-warm-sand transition-colors hover:bg-terracotta/90">
              {t('home.news.cta')}
            </button>
          </div>
        </form>
      </div>
    </div>
  </section>

  <!-- Hero search → Google site-search (no backend). If JS is off, the form action is the fallback. -->
  <script is:inline>
    document.getElementById('hero-search')?.addEventListener('submit', (event) => {
      event.preventDefault();
      const q = document.getElementById('site-search')?.value.trim();
      if (!q) return;
      const url = 'https://www.google.com/search?q=' + encodeURIComponent('site:petspro.netlify.app ' + q);
      window.open(url, '_blank', 'noopener');
    });
  </script>
</BaseLayout>
