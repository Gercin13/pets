---
// Article page. Renders a post from the blog collection and links its translations so
// the language switcher jumps to the SAME article in another language.
import { getCollection } from 'astro:content';
import BaseLayout from '../../../layouts/BaseLayout.astro';
import { getTranslationLinks } from '../../../lib/posts';
import { getLangFromUrl, localizePath, useTranslations } from '../../../i18n/utils';

export async function getStaticPaths() {
  const posts = await getCollection('blog');
  return posts.map((post) => {
    const [lang, ...rest] = post.slug.split('/'); // "de/impfratgeber" → lang="de", slug="impfratgeber"
    return { params: { lang, slug: rest.join('/') }, props: { post } };
  });
}

const { post } = Astro.props;
const { Content } = await post.render();
const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);
const localeLinks = await getTranslationLinks(post); // { en, de, uk } → real translation URLs
const dateStr = post.data.date
  ? new Date(post.data.date).toLocaleDateString(lang, { year: 'numeric', month: 'long', day: 'numeric' })
  : '';
---

<BaseLayout title={post.data.title} description={post.data.description} localeLinks={localeLinks}>
  <article class="mx-auto max-w-[720px] px-4 py-10 sm:px-6 lg:py-16">
    <nav aria-label="Breadcrumb" class="font-sans text-label-sm text-charcoal/50">
      <a href={localizePath('/', lang)} class="transition-colors hover:text-charcoal">{t('crumb.home')}</a>
      <span aria-hidden="true" class="px-1.5 text-charcoal/30">/</span>
      <a href={localizePath('/health', lang)} class="transition-colors hover:text-charcoal">{t('nav.health')}</a>
    </nav>

    {post.data.category && (
      <span class="mt-6 inline-block rounded-full bg-terracotta px-3 py-1 font-sans text-label-sm font-bold text-warm-sand">
        {post.data.category}
      </span>
    )}

    <h1 class="mt-4 font-serif text-[2rem] font-bold leading-tight text-charcoal md:text-4xl">{post.data.title}</h1>

    <div class="mt-3 font-sans text-label-sm text-charcoal/50">
      {post.data.author && <span>{post.data.author}</span>}
      {post.data.author && dateStr && <span aria-hidden="true" class="px-1.5">·</span>}
      {dateStr && <time>{dateStr}</time>}
    </div>

    <div class="article-body mt-8">
      <Content />
    </div>
  </article>
</BaseLayout>

<style is:global>
  /* Reading typography for rendered Markdown (dependency-free; :where() keeps specificity low). */
  .article-body :where(p):not(:where(.not-prose, .not-prose *)) { margin: 1.25rem 0; font-size: 1.0625rem; line-height: 1.75; color: rgba(30,27,24,.85); }
  .article-body :where(h2):not(:where(.not-prose, .not-prose *)) { margin: 2.25rem 0 .75rem; font-family: "Source Serif 4", Georgia, serif; font-size: 1.6rem; font-weight: 700; line-height: 1.25; color: #1e1b18; }
  .article-body :where(h3):not(:where(.not-prose, .not-prose *)) { margin: 1.75rem 0 .5rem; font-family: "Source Serif 4", Georgia, serif; font-size: 1.3rem; font-weight: 700; color: #1e1b18; }
  .article-body :where(ul, ol):not(:where(.not-prose, .not-prose *)) { margin: 1.25rem 0; padding-left: 1.4rem; font-size: 1.0625rem; line-height: 1.75; color: rgba(30,27,24,.85); }
  .article-body :where(ul):not(:where(.not-prose, .not-prose *)) { list-style: disc; }
  .article-body :where(ol):not(:where(.not-prose, .not-prose *)) { list-style: decimal; }
  .article-body :where(li):not(:where(.not-prose, .not-prose *)) { margin: .4rem 0; }
  .article-body :where(li)::marker { color: #334f2b; }
  .article-body :where(a):not(:where(.not-prose, .not-prose *)) { color: #334f2b; font-weight: 500; text-decoration: underline; text-underline-offset: 2px; }
  .article-body :where(strong):not(:where(.not-prose, .not-prose *)) { color: #1e1b18; font-weight: 700; }
  .article-body :where(blockquote):not(:where(.not-prose, .not-prose *)) { margin: 2rem 0; border-left: 4px solid #822a19; background: rgba(130,42,25,.04); padding: 1rem 1.5rem; border-radius: 0 .5rem .5rem 0; font-family: "Source Serif 4", Georgia, serif; font-style: italic; font-size: 1.25rem; line-height: 1.6; color: #1e1b18; }
</style>
