---
// Category page: Health & Care.
// Route: /en/health, /de/health, /uk/health (Header links here via localizePath).
// Content is held as a data object below — swap for an Astro content collection
// or the i18n dictionary to localize. Images live in /public/img/... (see values).
import { languages } from '../../i18n/ui';
import BaseLayout from '../../layouts/BaseLayout.astro';
import { getLangFromUrl, useTranslations, localizePath, readingTime } from '../../i18n/utils';

export function getStaticPaths() {
  return Object.keys(languages).map((lang) => ({ params: { lang } }));
}

const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);

const intro =
  'Trustworthy, vet-reviewed guidance on keeping your companion healthy — from routine care and vaccinations to first aid and dental hygiene.';

const petTypes = ['Dogs', 'Cats', 'Rodents'];
const categories = ['All topics', 'Vaccination', 'Dentistry', 'First aid'];

const featured = {
  badge: 'Featured',
  readingMinutes: 8,
  date: 'July 2, 2026',
  title: 'The Complete Guide to Pet Vaccination',
  excerpt:
    'What to vaccinate against, when, and why — a clear schedule for puppies, kittens, and adult pets, reviewed by our veterinary team.',
  href: '#',
  image: '/img/health/sleeping-dog.jpg',
  imageAlt: 'A dog sleeping peacefully wrapped in a cozy blanket',
};

const expert = {
  name: 'Dr. Anna Smirnova',
  badge: 'Expert of the Month',
  bio: 'Small-animal veterinarian with 12 years in preventive care and internal medicine. She reviews every Health & Care article for accuracy.',
  href: '#',
  avatar: '/img/authors/anna-smirnova.jpg',
  avatarAlt: 'Portrait of Dr. Anna Smirnova',
};

const articles = [
  {
    category: 'Dentistry',
    readingMinutes: 5,
    date: 'June 28, 2026',
    title: 'How to Train Your Cat to Accept Teeth Cleaning',
    excerpt:
      'A gentle, step-by-step routine to make brushing a stress-free habit for even the fussiest cats.',
    href: '#',
    image: '/img/health/cat-teeth.jpg',
    imageAlt: 'A cat having its teeth brushed',
  },
  {
    category: 'Nutrition',
    readingMinutes: 6,
    date: 'June 24, 2026',
    title: 'Dangerous Foods Hiding in Your Kitchen',
    excerpt:
      'Chocolate, grapes, onions and more — the everyday foods that are toxic to pets, and what to do if one is eaten.',
    href: '#',
    image: '/img/health/toxic-foods.jpg',
    imageAlt: 'Foods that are toxic to pets arranged on a table',
  },
];
---

<BaseLayout title="Health & Care — PetExpert">
  <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
    <!-- 1 · Breadcrumbs -->
    <nav aria-label="Breadcrumb" class="pt-6">
      <ol class="flex items-center gap-2 font-sans text-label-sm text-charcoal/50">
        <li><a href={localizePath('/', lang)} class="transition-colors hover:text-charcoal">{t('crumb.home')}</a></li>
        <li aria-hidden="true" class="text-charcoal/30">
          <svg viewBox="0 0 20 20" fill="currentColor" class="h-3.5 w-3.5">
            <path fill-rule="evenodd" d="M7.21 14.77a.75.75 0 0 1 .02-1.06L11.168 10 7.23 6.29a.75.75 0 1 1 1.04-1.08l4.5 4.25a.75.75 0 0 1 0 1.08l-4.5 4.25a.75.75 0 0 1-1.06-.02Z" clip-rule="evenodd" />
          </svg>
        </li>
        <li aria-current="page" class="font-medium text-charcoal/70">{t('nav.health')}</li>
      </ol>
    </nav>

    <!-- 2 · Section header -->
    <header class="max-w-3xl pb-10 pt-6">
      <h1 class="font-serif text-[2rem] font-bold leading-tight text-charcoal md:text-5xl">
        Health &amp; Care
      </h1>
      <p class="mt-4 font-sans text-lg leading-relaxed text-charcoal/70">{intro}</p>
    </header>

    <!-- 3 · Two-column layout (sidebar 1/4 · main 3/4) -->
    <div class="grid grid-cols-1 gap-8 pb-16 lg:grid-cols-4">
      <!-- Sidebar — drops below the main content on mobile (order-last) -->
      <aside class="order-last space-y-6 lg:order-none lg:col-span-1 lg:sticky lg:top-24 lg:self-start">
        <!-- Filters card -->
        <form class="rounded-lg bg-surface-lowest p-6 shadow-sm ring-1 ring-charcoal/5">
          <h2 class="font-serif text-lg font-bold text-charcoal">Filters</h2>

          <fieldset class="mt-5">
            <legend class="font-sans text-label-sm font-bold uppercase text-charcoal/50">Pet Type</legend>
            <div class="mt-3 space-y-2.5">
              {
                petTypes.map((type) => (
                  <label class="flex cursor-pointer items-center gap-3 font-sans text-sm text-charcoal">
                    <input type="checkbox" name="pet-type" value={type} class="h-4 w-4 rounded border-outline accent-primary" />
                    {type}
                  </label>
                ))
              }
            </div>
          </fieldset>

          <fieldset class="mt-6">
            <legend class="font-sans text-label-sm font-bold uppercase text-charcoal/50">Categories</legend>
            <div class="mt-3 space-y-2.5">
              {
                categories.map((cat, i) => (
                  <label class="flex cursor-pointer items-center gap-3 font-sans text-sm text-charcoal">
                    <input type="radio" name="category" value={cat} checked={i === 0} class="h-4 w-4 border-outline accent-primary" />
                    {cat}
                  </label>
                ))
              }
            </div>
          </fieldset>
        </form>

        <!-- CTA card -->
        <div class="rounded-lg border border-dashed border-outline-variant bg-warm-sand p-6">
          <h2 class="font-serif text-lg font-bold text-charcoal">Need urgent advice?</h2>
          <p class="mt-2 font-sans text-sm leading-relaxed text-charcoal/70">
            Ask our on-call veterinarians — most questions get a reply within a few hours.
          </p>
          <a
            href="#"
            class="mt-4 inline-flex w-full items-center justify-center rounded-lg bg-terracotta px-5 py-2.5 font-sans text-label-bold text-warm-sand transition-colors hover:bg-terracotta/90"
          >
            Ask a Question
          </a>
        </div>
      </aside>

      <!-- Main content -->
      <div class="space-y-8 lg:col-span-3">
        <!-- Featured article (horizontal) -->
        <article class="overflow-hidden rounded-lg bg-surface-lowest shadow-sm ring-1 ring-charcoal/5">
          <div class="flex flex-col md:flex-row">
            <div class="relative md:w-2/5">
              <img src={featured.image} alt={featured.imageAlt} class="h-56 w-full object-cover md:h-full" loading="lazy" />
              <span class="absolute left-4 top-4 rounded-full bg-terracotta px-3 py-1 font-sans text-label-sm font-bold text-warm-sand shadow-sm">
                {featured.badge}
              </span>
            </div>
            <div class="flex flex-1 flex-col justify-center p-6 md:p-8">
              <div class="flex items-center gap-2 font-sans text-label-sm text-charcoal/50">
                <span>{readingTime(featured.readingMinutes, lang)}</span>
                <span aria-hidden="true">·</span>
                <span>{featured.date}</span>
              </div>
              <h2 class="mt-3 font-serif text-2xl font-bold leading-snug text-charcoal md:text-3xl">
                <a href={featured.href} class="transition-colors hover:text-primary">{featured.title}</a>
              </h2>
              <p class="mt-3 font-sans leading-relaxed text-charcoal/70">{featured.excerpt}</p>
              <a href={featured.href} class="group mt-5 inline-flex items-center gap-2 font-sans text-label-bold text-primary">
                Read Article
                <svg viewBox="0 0 20 20" fill="currentColor" class="h-4 w-4 transition-transform group-hover:translate-x-1">
                  <path fill-rule="evenodd" d="M3 10a.75.75 0 0 1 .75-.75h10.638L10.23 5.29a.75.75 0 1 1 1.04-1.08l5.5 5.25a.75.75 0 0 1 0 1.08l-5.5 5.25a.75.75 0 1 1-1.04-1.08l4.158-3.96H3.75A.75.75 0 0 1 3 10Z" clip-rule="evenodd" />
                </svg>
              </a>
            </div>
          </div>
        </article>

        <!-- Expert banner (E-E-A-T) -->
        <aside class="rounded-lg bg-gradient-to-r from-surface-lowest to-primary-soft p-6 ring-1 ring-primary/10 md:p-8">
          <div class="flex flex-col items-center gap-5 text-center sm:flex-row sm:text-left">
            <img src={expert.avatar} alt={expert.avatarAlt} class="h-20 w-20 shrink-0 rounded-full object-cover ring-4 ring-surface-lowest" loading="lazy" />
            <div class="flex-1">
              <span class="inline-flex items-center gap-1.5 rounded-full bg-primary/10 px-3 py-1 font-sans text-label-sm font-bold text-primary">
                <svg viewBox="0 0 20 20" fill="currentColor" class="h-3.5 w-3.5">
                  <path fill-rule="evenodd" d="M10.868 2.884c-.321-.772-1.415-.772-1.736 0l-1.83 4.401-4.753.381c-.833.067-1.171 1.107-.536 1.651l3.62 3.102-1.106 4.637c-.194.813.691 1.456 1.405 1.02L10 15.591l4.069 2.485c.713.436 1.598-.207 1.404-1.02l-1.106-4.637 3.62-3.102c.635-.544.297-1.584-.536-1.65l-4.752-.382-1.831-4.4Z" clip-rule="evenodd" />
                </svg>
                {expert.badge}
              </span>
              <h3 class="mt-2 font-serif text-xl font-bold text-charcoal">{expert.name}</h3>
              <p class="mt-1 font-sans text-sm leading-relaxed text-charcoal/70">{expert.bio}</p>
            </div>
            <a href={expert.href} class="shrink-0 rounded-lg border border-primary/40 px-5 py-2.5 font-sans text-label-bold text-primary transition-colors hover:bg-primary hover:text-warm-sand">
              All Articles
            </a>
          </div>
        </aside>

        <!-- Article grid (two-up) -->
        <div class="grid grid-cols-1 gap-6 sm:grid-cols-2">
          {
            articles.map((article) => (
              <article class="group flex flex-col overflow-hidden rounded-lg bg-surface-lowest shadow-sm ring-1 ring-charcoal/5 transition-shadow hover:shadow-md">
                <div class="relative">
                  <img src={article.image} alt={article.imageAlt} class="h-48 w-full object-cover" loading="lazy" />
                  <span class="absolute left-3 top-3 rounded-full bg-terracotta px-2.5 py-1 font-sans text-label-sm font-bold text-warm-sand shadow-sm">
                    {article.category}
                  </span>
                </div>
                <div class="flex flex-1 flex-col p-5">
                  <div class="flex items-center gap-2 font-sans text-label-sm text-charcoal/50">
                    <span>{readingTime(article.readingMinutes, lang)}</span>
                    <span aria-hidden="true">·</span>
                    <span>{article.date}</span>
                  </div>
                  <h3 class="mt-2 font-serif text-lg font-bold leading-snug text-charcoal">
                    <a href={article.href} class="transition-colors hover:text-primary">{article.title}</a>
                  </h3>
                  <p class="mt-2 flex-1 font-sans text-sm leading-relaxed text-charcoal/70">{article.excerpt}</p>
                </div>
              </article>
            ))
          }
        </div>

        <!-- 4 · Load more -->
        <div class="flex justify-center pt-2">
          <button
            type="button"
            class="inline-flex items-center gap-2 rounded-lg bg-surface-container px-6 py-3 font-sans text-label-bold text-charcoal transition-colors hover:bg-surface-container-high"
          >
            Show More
            <svg viewBox="0 0 20 20" fill="currentColor" class="h-4 w-4">
              <path fill-rule="evenodd" d="M5.23 7.21a.75.75 0 0 1 1.06.02L10 11.168l3.71-3.938a.75.75 0 1 1 1.08 1.04l-4.25 4.5a.75.75 0 0 1-1.08 0l-4.25-4.5a.75.75 0 0 1 .02-1.06Z" clip-rule="evenodd" />
            </svg>
          </button>
        </div>
      </div>
    </div>
  </div>
</BaseLayout>
