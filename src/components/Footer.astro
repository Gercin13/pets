---
// Global site footer — "Warm Professionalism".
// Left: logo + serif tagline + copyright. Right: legal/company links. Bottom: affiliate disclosure.
import { getLangFromUrl, useTranslations, localizePath } from '../i18n/utils';
import { footerLinks } from '../i18n/ui';

const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);
const year = new Date().getFullYear();
---

<footer class="border-t border-charcoal/10 bg-warm-sand">
  <div class="mx-auto max-w-7xl px-4 py-12 sm:px-6 lg:px-8">
    <div class="flex flex-col gap-10 md:flex-row md:items-start md:justify-between">
      <!-- Left column -->
      <div class="max-w-sm">
        <a href={localizePath('/', lang)} class="font-serif text-2xl font-bold tracking-tight text-primary">
          PetExpert
        </a>
        <p class="mt-3 font-serif text-lg italic text-charcoal/80">{t('footer.tagline')}</p>
        <p class="mt-5 font-sans text-label-sm text-charcoal/50">
          © {year} PetExpert. {t('footer.rights')}
        </p>
      </div>

      <!-- Company / legal links -->
      <nav aria-label={t('a11y.footerNav')}>
        <ul class="flex flex-col gap-3 sm:flex-row sm:flex-wrap sm:gap-x-8 sm:gap-y-3">
          {
            footerLinks.map((item) => (
              <li>
                <a
                  href={localizePath(item.href, lang)}
                  class="font-sans text-label-bold text-charcoal transition-colors hover:text-primary"
                >
                  {t(item.key)}
                </a>
              </li>
            ))
          }
        </ul>
      </nav>
    </div>

    <!-- Affiliate disclaimer -->
    <div class="mt-10 border-t border-charcoal/10 pt-6">
      <p class="max-w-2xl font-sans text-label-sm text-charcoal/50">
        {t('footer.disclosure')}
      </p>
    </div>
  </div>
</footer>
